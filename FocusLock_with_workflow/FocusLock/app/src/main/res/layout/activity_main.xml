<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D1117">

    <!-- Logo / Judul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="64sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FocusLock"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kunci HP, fokus sepenuhnya."
        android:textSize="14sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="48dp" />

    <!-- Label Durasi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Durasi Fokus"
        android:textSize="16sp"
        android:textColor="#C9D1D9"
        android:layout_marginBottom="24dp" />

    <!-- Picker Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_picker"
        android:padding="16dp"
        android:layout_marginBottom="48dp">

        <!-- Jam -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JAM"
                android:textSize="11sp"
                android:textColor="#8B949E"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <NumberPicker
                android:id="@+id/pickerHours"
                android:layout_width="80dp"
                android:layout_height="120dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingHorizontal="8dp" />

        <!-- Menit -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MENIT"
                android:textSize="11sp"
                android:textColor="#8B949E"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <NumberPicker
                android:id="@+id/pickerMinutes"
                android:layout_width="80dp"
                android:layout_height="120dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Tombol Mulai -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="🚀  Mulai Sesi Fokus"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#58A6FF"
        android:stateListAnimator="@null" />

    <!-- Info DND -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Semua notifikasi akan dibisukan selama sesi."
        android:textSize="12sp"
        android:textColor="#8B949E"
        android:gravity="center"
        android:layout_marginTop="16dp" />

</LinearLayout>
